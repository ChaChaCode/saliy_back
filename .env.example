# ──────────────────────────────────────────────────────────────
# Пример переменных окружения для saliy_back.
# Скопируй в .env и заполни реальными значениями. .env в .gitignore.
# Секреты НЕ коммитить — здесь только плейсхолдеры.
# ──────────────────────────────────────────────────────────────

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/saliy_db"

# Email (Gmail SMTP). EMAIL_PASS — App Password Gmail (16 символов без пробелов).
# EMAIL_FROM должен совпадать с EMAIL_USER для доставляемости.
EMAIL_USER=example@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM=example@gmail.com

# Yandex Object Storage (S3)
YANDEX_ACCESS_KEY=your_s3_access_key
YANDEX_SECRET_KEY=your_s3_secret_key
YANDEX_BUCKET=saliy-shop
YANDEX_ENDPOINT=https://storage.yandexcloud.net
YANDEX_REGION=ru-central1

# CORS: домены фронта/админки через запятую (без пробелов)
CORS_ORIGINS=https://saliyclothes.com,https://www.saliyclothes.com,https://admin.saliyclothes.com,http://localhost:3000,http://localhost:5173

FRONTEND_URL=https://saliyclothes.com
BACKEND_URL=https://saliyclothes.com/api

# Через сколько минут неоплаченный онлайн-заказ (PENDING) автоматически
# отменяется, а товар возвращается на склад. По умолчанию 15.
ORDER_PENDING_TIMEOUT_MIN=15

# Управление SameSite для auth-cookie: lax | none | strict
# none — для cross-site (Vercel), требует Secure. lax — один домен.
COOKIE_SAMESITE=lax

# Секрет для проверки заголовка X-Telegram-Bot-Api-Secret-Token вебхука
TELEGRAM_WEBHOOK_SECRET=replace_with_random_hex

# ── CDEK Доставка ──
# true — тестовый режим (берёт *_TEST креды), false — продакшн
CDEK_TEST_MODE=false
CDEK_CLIENT_ID_TEST=your_cdek_test_client_id
CDEK_CLIENT_SECRET_TEST=your_cdek_test_client_secret
CDEK_CLIENT_ID=your_cdek_prod_client_id
CDEK_CLIENT_SECRET=your_cdek_prod_client_secret
# Код города склада отправления (НЕ телефонный код!). Санкт-Петербург=137.
# Узнать: GET /api/delivery/cities?countryCode=RU&search=Москва
CDEK_WAREHOUSE_CITY_CODE=137
# Отправитель в накладной CDEK (показывается в посылке). Телефон — реальный РФ.
CDEK_SENDER_NAME=SALIY
CDEK_SENDER_PHONE=+79000000000

# JWT (сгенерировать случайные: openssl rand -hex 32)
JWT_ACCESS_SECRET=replace_with_random_hex_32
JWT_ADMIN_SECRET=replace_with_random_hex_32

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=your_bot_token
# Секретный канал (создание первого админа, уведомления)
TELEGRAM_CHANNEL_ID=-1000000000000
# Канал для бэкапов БД (/dump и автоматические раз в 3 дня)
TELEGRAM_CHANNEL_ID_DUMP=-1000000000000

# ── Yandex Pay (Яндекс Сплит) ──
# Прод: YANDEX_PAY_SANDBOX=false (endpoint станет pay.yandex.ru)
YANDEX_PAY_SANDBOX=true
YANDEX_PAY_MERCHANT_ID=your_yandex_merchant_id
YANDEX_PAY_API_KEY=your_yandex_api_key
# Какие методы показывать в Яндекс Пэй (через запятую). По умолчанию только SPLIT.
# Примеры: SPLIT | SPLIT,CARD | CARD,SPLIT,SBP
YANDEX_PAY_METHODS=SPLIT
# Секрет для проверки подписи вебхука Яндекса («Секрет для подписи» из кабинета)
YANDEX_PAY_WEBHOOK_SECRET=your_yandex_webhook_secret
# Polling статуса оплат Яндекса (фолбэк к webhook). false — отключить.
YANDEX_POLLING_ENABLED=true

# ── Alfa Bank (ОТКЛЮЧЕНА, код спящий) ──
# Прод: https://pay.alfabank.ru. Код валюты: RUB=810 (легаси, не ISO 643!).
ALFA_BASE_URL=https://alfa.rbsuat.com
ALFA_API_USERNAME=your_alfa_api_username
ALFA_API_PASSWORD=your_alfa_api_password
ALFA_CURRENCY=810

# ── Банк Точка (интернет-эквайринг СБП/карта) ──
# TOCHKA_CUSTOMER_CODE — реальный бизнес-счёт из GET /uapi/open-banking/v1.0/accounts
# TOCHKA_MERCHANT_ID — торговая точка из GET /uapi/acquiring/v1.0/retailers
TOCHKA_JWT_TOKEN=your_tochka_jwt_token
TOCHKA_CUSTOMER_CODE=your_customer_code
TOCHKA_MERCHANT_ID=your_merchant_id
# Polling статуса оплат Точки (фолбэк, пока webhook не зарегистрирован).
# Раз в минуту опрашивает PENDING-заказы и подтверждает оплату.
# Поставить false, когда заработает webhook acquiringInternetPayment.
TOCHKA_POLLING_ENABLED=true
