// Модель для баннеров магазина

model Banner {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Основная информация
  title       String  @map("title") // Название баннера (для админки)
  description String? @map("description") // Описание (опционально)

  // Изображения
  desktopImageUrl String @map("desktop_image_url") // URL изображения для десктопа
  mobileImageUrl  String @map("mobile_image_url") // URL изображения для мобильной версии

  // Ссылка при клике
  link String? @map("link") // URL для перехода при клике (опционально)

  // Связь с категорией (опционально)
  categoryId Int?      @map("category_id") // ID категории (null = баннер для главной страницы)
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Настройки отображения
  order    Int     @default(0) @map("order") // Порядок отображения (меньше = выше)
  isActive Boolean @default(true) @map("is_active") // Активен ли баннер

  @@index([categoryId])
  @@index([isActive])
  @@index([categoryId, isActive])
  @@map("banners")
}
