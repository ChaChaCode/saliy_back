// Модели для авторизации

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Персональная информация
  firstName  String? @map("first_name")
  lastName   String? @map("last_name")
  middleName String? @map("middle_name")
  phone      String? @map("phone")

  // Контакты для связи
  username  String? @map("username")    // Имя пользователя
  telegram  String? @map("telegram")    // Telegram username (@username)
  instagram String? @map("instagram")   // Instagram username (@username)

  // Адрес доставки (для заказов)
  street     String? @map("street")
  apartment  String? @map("apartment")
  postalCode String? @map("postal_code")

  // Тип доставки (выбирает пользователь первым шагом)
  // CDEK - самовывоз из ПВЗ CDEK (только RU/BY)
  // POST - обычная почтовая доставка (любая страна)
  deliveryType String? @map("delivery_type")

  // CDEK доставка (если deliveryType = CDEK)
  cdekCityCode        Int?    @map("cdek_city_code")
  cdekCountryCode     String? @map("cdek_country_code")
  cdekRegionCode      Int?    @map("cdek_region_code")
  cdekPickupPointCode String? @map("cdek_pickup_point_code") // Код выбранного ПВЗ
  cityName            String? @map("city_name")
  countryName         String? @map("country_name")
  regionName          String? @map("region_name")

  // Почтовая доставка (если deliveryType = POST)
  deliveryCountryCode String? @map("delivery_country_code") // Код страны (US, PL, RU, etc)
  fullAddress         String? @map("full_address")          // Полный адрес одной строкой

  refreshTokens     RefreshToken[]
  verificationCodes VerificationCode[]
  orders            Order[]
  cartItems         CartItem[]
}

model VerificationCode {
  id        String   @id @default(uuid())
  code      String
  email     String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String?

  @@index([email, verified])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}
